{
    "name": "meditech-npr",
    "displayName": "MEDITECH NPR",
    "description": "Syntax highlighting for MEDITECH NPR/MAGIC code",
    "version": "0.0.1",
    "publisher": "nocalla",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/nocalla/meditech-npr"
    },
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": ["Programming Languages"],
    "contributes": {
        "languages": [
            {
                "id": "npr",
                "aliases": ["MEDITECH NPR", "NPR"],
                "extensions": [".npr", ".pha", ".rw"]
            }
        ],
        "grammars": [
            {
                "language": "npr",
                "scopeName": "source.npr",
                "path": "./syntaxes/meditech-npr.tmLanguage.json"
            }
        ]
    },
    "scripts": {
        "package": "vsce package"
    },
    "devDependencies": {
        "@vscode/vsce": "2.15.0"
    },
    "overrides": {
        "undici": "5.28.4"
    }
}
